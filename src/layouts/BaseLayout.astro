---
// src/layouts/BaseLayout.astro
// Root layout for all pages.
// Imports the design-system token layer and global base styles.
// Astro Fonts API: Font component emits preload + @font-face for Cinzel and Inter.

import '../styles/tokens.css';
import '../styles/global.css';
import { Font } from 'astro:assets';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Vietnam-focused financial research by Saigon Equities Forum.',
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <!-- Astro Fonts API: emits preload links + @font-face with font-display:swap (BRD-04) -->
    <Font cssVariable="--font-cinzel" preload />
    <Font cssVariable="--font-inter" preload />
  </head>
  <body>
    <slot />
  </body>
</html>
