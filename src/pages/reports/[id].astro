---
// src/pages/reports/[id].astro
// Dynamic report detail page — one route per MDX report in the collection.
//
// MOD-02: imports ONLY from ../../lib/content — never from astro:content directly.
// getStaticPaths() generates one route per report entry id.
// render() renders the MDX body through the adapter seam.

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getReports, getReport, render } from '../../lib/content';

export async function getStaticPaths() {
  const reports = await getReports();
  return reports.map((report) => ({
    params: { id: report.id },
  }));
}

const { id } = Astro.params;
const report = await getReport(id);

// Safety guard — should never be undefined since getStaticPaths() drives routing.
if (!report) {
  return Astro.redirect('/404');
}

const { Content } = await render(report);

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(report.data.publishedAt);
---

<BaseLayout
  title={`${report.data.title} | Saigon Equities Forum`}
  description={report.data.description}
>
  <article class="report-page">
    <header class="report-header">
      <div class="report-meta">
        <span class="report-division">{report.data.division}</span>
        <span class="report-type">{report.data.type}</span>
        {report.data.sector.map((s) => (
          <span class="report-sector">{s}</span>
        ))}
      </div>

      <h1 class="report-title" data-display>{report.data.title}</h1>

      <p class="report-description">{report.data.description}</p>

      <div class="report-byline">
        <span class="report-analysts">
          {report.data.analysts.join(', ')}
        </span>
        <span class="report-date">{formattedDate}</span>
      </div>

      {/* PDF download — uses --color-accent per WCAG role split (D-04) */}
      <a
        href={report.data.pdfUrl}
        class="report-pdf-link"
        target="_blank"
        rel="noopener noreferrer"
      >
        Read full report (PDF)
      </a>
    </header>

    <div class="report-content">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .report-page {
    max-width: 800px;
    margin-inline: auto;
    padding: var(--space-4xl) var(--space-xl) var(--space-5xl);
  }

  /* Header */
  .report-header {
    border-bottom: 1px solid var(--color-surface-3);
    margin-bottom: var(--space-3xl);
    padding-bottom: var(--space-2xl);
  }

  .report-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
  }

  .report-division,
  .report-type,
  .report-sector {
    font-family: var(--font-body);
    font-size: var(--text-label);
    font-weight: 400;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    background: var(--color-surface-2);
    border: 1px solid var(--color-surface-3);
    padding: 2px var(--space-sm);
    border-radius: 2px;
  }

  .report-division {
    color: var(--color-accent);
    border-color: var(--color-accent);
    background: transparent;
  }

  .report-title {
    font-family: var(--font-display);
    font-size: var(--text-heading);
    font-weight: 400;
    color: var(--color-ink);
    line-height: 1.2;
    margin: 0 0 var(--space-lg) 0;
  }

  .report-description {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-ink-muted);
    line-height: 1.7;
    max-width: 65ch;
    margin: 0 0 var(--space-xl) 0;
  }

  .report-byline {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    align-items: center;
    font-family: var(--font-body);
    font-size: var(--text-label);
    color: var(--color-ink-muted);
    margin-bottom: var(--space-xl);
  }

  .report-analysts {
    font-weight: 400;
  }

  .report-date::before {
    content: '·';
    margin-right: var(--space-md);
  }

  /* PDF link — accent color per WCAG role split D-04 (--color-accent is the link color) */
  .report-pdf-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-body);
    font-size: var(--text-body);
    font-weight: 400;
    color: var(--color-accent);
    text-decoration: none;
    border: 1px solid var(--color-accent);
    padding: var(--space-sm) var(--space-lg);
    border-radius: 2px;
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  .report-pdf-link:hover {
    background: var(--color-accent);
    color: var(--color-surface);
  }

  .report-pdf-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  /* MDX body */
  .report-content {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-ink);
    line-height: 1.75;
  }

  .report-content :global(h2) {
    font-family: var(--font-display);
    font-size: var(--text-heading);
    font-weight: 400;
    color: var(--color-ink);
    margin: var(--space-3xl) 0 var(--space-lg) 0;
    border-bottom: 1px solid var(--color-gold);
    padding-bottom: var(--space-sm);
  }

  .report-content :global(h3) {
    font-family: var(--font-body);
    font-size: 1.125rem;
    font-weight: 400;
    color: var(--color-ink);
    margin: var(--space-2xl) 0 var(--space-md) 0;
  }

  .report-content :global(p) {
    margin: 0 0 var(--space-lg) 0;
    max-width: 72ch;
  }

  .report-content :global(ul),
  .report-content :global(ol) {
    margin: 0 0 var(--space-lg) var(--space-lg);
    max-width: 68ch;
  }

  .report-content :global(li) {
    margin-bottom: var(--space-sm);
  }

  .report-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-label);
    margin: var(--space-xl) 0;
    font-family: Arial, sans-serif; /* brand rule: Arial for tables/graphs */
  }

  .report-content :global(th) {
    background: var(--color-surface-2);
    color: var(--color-ink);
    font-weight: 400;
    text-align: left;
    padding: var(--space-sm) var(--space-md);
    border-bottom: 2px solid var(--color-surface-3);
  }

  .report-content :global(td) {
    padding: var(--space-sm) var(--space-md);
    border-bottom: 1px solid var(--color-surface-3);
    color: var(--color-ink);
  }

  .report-content :global(tr:last-child td) {
    border-bottom: none;
  }

  .report-content :global(blockquote) {
    border-left: 3px solid var(--color-gold);
    margin: var(--space-xl) 0;
    padding: var(--space-md) var(--space-xl);
    background: var(--color-surface-2);
    font-style: normal;
  }

  .report-content :global(blockquote p) {
    margin: 0;
    color: var(--color-ink);
  }

  .report-content :global(img) {
    max-width: 100%;
    height: auto;
    display: block;
    margin: var(--space-xl) 0;
    border: 1px solid var(--color-surface-3);
  }

  .report-content :global(em) {
    color: var(--color-ink-muted);
    font-style: italic;
  }

  .report-content :global(strong) {
    font-weight: 600;
    color: var(--color-ink);
  }

  .report-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-surface-3);
    margin: var(--space-3xl) 0;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .report-page {
      padding: var(--space-3xl) var(--space-md) var(--space-4xl);
    }
  }
</style>
