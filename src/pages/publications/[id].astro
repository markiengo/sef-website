---
// src/pages/publications/[id].astro
// Dynamic report detail page — one route per MDX report in the collection.
//
// MOD-02: imports ONLY from ../../lib/content — never from astro:content directly.
// getStaticPaths() generates one route per report entry id.
// render() renders the MDX body through the adapter seam.

import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { getReports, getReport, render } from '../../lib/content';
import { slugify } from '../../lib/slugify';

export async function getStaticPaths() {
  const reports = await getReports();
  return reports.map((report) => ({
    params: { id: report.id },
  }));
}

const { id } = Astro.params;
const report = await getReport(id);

// Safety guard — should never be undefined since getStaticPaths() drives routing.
if (!report) {
  return Astro.redirect('/404');
}

const { Content } = await render(report);

const formattedDate = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(report.data.publishedAt);

// Related posts — the 3 entries following this one in the newest-first list
// (wrapping around), so every page surfaces a varied trio rather than the same one.
const all = await getReports();
const idx = all.findIndex((r) => r.id === report.id);
const related: typeof all = [];
for (let i = 1; related.length < 3 && i < all.length; i++) {
  const cand = all[(idx + i) % all.length];
  if (cand.id !== report.id) related.push(cand);
}
---

<BaseLayout
  title={`${report.data.title} | Saigon Equities Forum`}
  description={report.data.description}
>
  <a href="/publications" class="report-back">← Publications</a>
  <article class="report-page">
    <header class="report-header">
      <div class="report-meta">
        <span class="report-division">{report.data.division}</span>
        <span class="report-type">{report.data.type}</span>
        {report.data.sector.map((s) => (
          <span class="report-sector">{s}</span>
        ))}
      </div>

      <h1 class="report-title" data-display>{report.data.title}</h1>

      {/* Lead cover image — sits directly under the title (same image used on the
          publications cards), grounding the page visually before the dek. */}
      <Image
        class="report-cover"
        src={report.data.cover}
        alt={report.data.title}
        widths={[480, 768, 1080]}
        sizes="(max-width: 767px) 100vw, 720px"
        loading="eager"
        fetchpriority="high"
      />

      <p class="report-description">{report.data.description}</p>

      <div class="report-byline">
        <span class="report-analysts">
          {report.data.analysts.map((name, i) => (
            <>
              {i > 0 && <span>, </span>}
              <a href={`/team/${slugify(name)}`}>{name}</a>
            </>
          ))}
        </span>
        <span class="report-date">{formattedDate}</span>
      </div>

      {/* Primary CTA — open the full PDF. Filled emerald button (--color-accent,
          8:1 on cream) per WCAG role split (D-04). The web page is a teaser;
          the full analysis lives in the PDF. Short-form Insight posts have no
          standalone PDF (pdfUrl "#") — the page IS the publication, so we drop
          the button rather than render a dead link. */}
      {report.data.pdfUrl !== '#' && (
        <a
          href={report.data.pdfUrl}
          class="report-pdf-cta"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`Read the full ${report.data.title} report as a PDF`}
        >
          <span>Read the full report (PDF)</span>
          <span class="report-pdf-cta__arrow" aria-hidden="true">→</span>
        </a>
      )}
    </header>

    {report.data.keyStats.length > 0 && (
      <dl class="report-stats" aria-label="Key figures">
        {report.data.keyStats.map((stat) => (
          <div class="report-stat">
            <dt class="report-stat__value">{stat.value}</dt>
            <dd class="report-stat__label">{stat.label}</dd>
          </div>
        ))}
      </dl>
    )}

    <div class="report-content">
      <Content />
    </div>
  </article>

  {related.length > 0 && (
    <section class="more-posts" aria-label="More publications">
      <div class="more-posts__head">
        <p class="more-posts__eyebrow">Keep reading</p>
        <h2 class="more-posts__heading">More from SEF</h2>
      </div>
      <div class="more-grid">
        {related.map((r) => (
          <a class="more-card" href={`/publications/${r.id}`}>
            <Image class="more-card__img" src={r.data.cover} alt="" widths={[320, 480, 640]} sizes="(max-width: 767px) 100vw, 360px" loading="lazy" />
            <span class="more-card__scrim" aria-hidden="true"></span>
            <span class="more-card__meta">{r.data.division} · {r.data.type}</span>
            <h3 class="more-card__title">{r.data.title}</h3>
          </a>
        ))}
      </div>
    </section>
  )}
</BaseLayout>

<style>
  /* Breadcrumb back link — sits above the article at the same max-width */
  .report-back {
    display: block;
    max-width: 800px;
    margin-inline: auto;
    padding: var(--space-4xl) var(--space-xl) 0;
    font-family: var(--font-body);
    font-size: var(--text-label);
    color: var(--color-accent);
    text-decoration: none;
    margin-bottom: var(--space-xl);
  }

  .report-back:hover {
    color: var(--color-ink);
  }

  /* Up-scale the whole report ~1.2x on desktop ("feels small" fix).
     Gated to >=1024px so the zoomed width (~960px) never overflows
     narrower viewports (zoom multiplies layout box, not just type). */
  @media (min-width: 1024px) {
    .report-back {
      zoom: 1.2;
    }
  }

  .report-page {
    max-width: 800px;
    margin-inline: auto;
    padding: var(--space-xl) var(--space-xl) var(--space-5xl);
  }

  @media (min-width: 1024px) {
    .report-page {
      zoom: 1.2;
    }
  }

  /* Header */
  .report-header {
    border-bottom: 1px solid var(--color-surface-3);
    margin-bottom: var(--space-3xl);
    padding-bottom: var(--space-2xl);
  }

  .report-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
  }

  .report-division,
  .report-type,
  .report-sector {
    font-family: var(--font-body);
    font-size: var(--text-label);
    font-weight: 400;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    background: var(--color-surface-2);
    border: 1px solid var(--color-surface-3);
    padding: 2px var(--space-sm);
    border-radius: 2px;
  }

  .report-division {
    color: var(--color-accent);
    border-color: var(--color-accent);
    background: transparent;
  }

  .report-title {
    font-family: var(--font-display);
    font-size: var(--text-heading);
    font-weight: 400;
    color: var(--color-ink);
    line-height: 1.2;
    margin: 0 0 var(--space-lg) 0;
  }

  /* Lead cover image — full column width, cinematic 16:9 crop, under the title. */
  .report-cover {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
    border-radius: 6px;
    border: 1px solid var(--color-surface-3);
    margin: 0 0 var(--space-xl) 0;
  }

  .report-description {
    font-family: var(--font-body);
    font-size: var(--text-body);
    font-weight: 400;
    color: var(--color-ink-muted);
    line-height: 1.7;
    max-width: none;        /* fill the column — no right-side dead space */
    text-align: justify;    /* match body: flush both edges */
    text-justify: auto;
    hyphens: auto;
    margin: 0 0 var(--space-xl) 0;
  }

  .report-byline {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    align-items: center;
    font-family: var(--font-body);
    font-size: var(--text-label);
    font-weight: 400;
    color: var(--color-ink-muted);
    margin-bottom: var(--space-xl);
  }

  .report-date::before {
    content: '·';
    margin-right: var(--space-md);
  }

  /* Primary CTA — filled emerald button (--color-accent fill, cream text = 8:1 AAA).
     This is the main action on the page: open the full report PDF. */
  .report-pdf-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-body);
    font-size: var(--text-body);
    font-weight: 700;            /* Butler Bold — strong, unmissable CTA */
    letter-spacing: 0.01em;
    color: var(--color-surface); /* cream text on emerald fill */
    background: var(--color-accent);
    text-decoration: none;
    padding: var(--space-md) var(--space-xl);
    border: 1px solid var(--color-accent);
    border-radius: 3px;
    transition: background-color 0.18s ease, border-color 0.18s ease,
      transform 0.18s ease, box-shadow 0.18s ease;
  }

  .report-pdf-cta:hover {
    background: var(--color-ink);
    border-color: var(--color-ink);
    color: var(--color-surface);
    transform: translateY(-1px);
    box-shadow: 0 6px 18px -8px rgba(29, 57, 55, 0.5);
  }

  .report-pdf-cta__arrow {
    transition: transform 0.18s ease;
  }

  .report-pdf-cta:hover .report-pdf-cta__arrow {
    transform: translateX(3px);
  }

  .report-pdf-cta:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
  }

  /* Key figures band — sits between header and body, like a research-note
     summary strip. Arial numerals (brand rule for data); responsive auto-fit. */
  .report-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: var(--space-lg);
    margin: 0 0 var(--space-3xl) 0;
    padding: var(--space-xl);
    background: var(--color-surface-2);
    border: 1px solid var(--color-surface-3);
    border-radius: 4px;
  }

  .report-stat {
    margin: 0;
    text-align: left;
  }

  .report-stat__value {
    font-family: Arial, sans-serif;   /* brand rule: Arial for numeric data */
    font-size: 1.6rem;
    font-weight: 700;
    line-height: 1.1;
    color: var(--color-ink);
    margin: 0;
  }

  .report-stat__label {
    font-family: var(--font-body);
    font-size: var(--text-label);
    font-weight: 400;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin: var(--space-xs) 0 0 0;
  }

  /* MDX body */
  .report-content {
    font-family: var(--font-body);
    font-size: var(--text-body);
    font-weight: 400;
    color: var(--color-ink);
    line-height: 1.75;
  }

  .report-content :global(h2) {
    font-family: var(--font-display);
    font-size: var(--text-heading);
    font-weight: 400;
    color: var(--color-ink);
    margin: var(--space-3xl) 0 var(--space-lg) 0;
    border-bottom: 2px solid var(--color-accent);
    padding-bottom: var(--space-sm);
  }

  .report-content :global(h3) {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--color-ink);
    margin: var(--space-2xl) 0 var(--space-md) 0;
    padding-left: var(--space-md);
    border-left: 3px solid var(--color-accent);
  }

  .report-content :global(p) {
    font-weight: 400;
    margin: 0 0 var(--space-lg) 0;
    max-width: none;
    text-align: justify;
    text-justify: auto;
    hyphens: auto;
    line-height: 1.8;
  }

  .report-content :global(ul),
  .report-content :global(ol) {
    margin: 0 0 var(--space-lg) var(--space-lg);
  }

  .report-content :global(li) {
    font-weight: 400;
    margin-bottom: var(--space-sm);
  }

  .report-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-label);
    margin: var(--space-xl) 0;
    font-family: Arial, sans-serif;
  }

  .report-content :global(th) {
    background: var(--color-surface-2);
    color: var(--color-ink);
    font-weight: 700;
    text-align: left;
    padding: var(--space-sm) var(--space-md);
    border-bottom: 2px solid var(--color-surface-3);
  }

  .report-content :global(td) {
    font-weight: 400;
    padding: var(--space-sm) var(--space-md);
    border-bottom: 1px solid var(--color-surface-3);
    color: var(--color-ink);
  }

  .report-content :global(tr:last-child td) {
    border-bottom: none;
  }

  .report-content :global(blockquote) {
    border-left: 3px solid var(--color-gold);
    margin: var(--space-xl) 0;
    padding: var(--space-md) var(--space-xl);
    background: var(--color-surface-2);
    font-style: normal;
  }

  .report-content :global(blockquote p) {
    font-weight: 400;
    margin: 0;
    color: var(--color-ink);
  }

  .report-content :global(img) {
    max-width: 100%;
    height: auto;
    display: block;
    margin: var(--space-xl) 0;
    border: 1px solid var(--color-surface-3);
    border-radius: 4px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  /* Figure exhibits — image + caption (used by report bodies that embed slides). */
  .report-content :global(figure) {
    margin: var(--space-2xl) 0;
  }

  .report-content :global(figure img) {
    margin: 0;
  }

  .report-content :global(figcaption) {
    margin-top: var(--space-sm);
    font-family: var(--font-body);
    font-size: var(--text-label);
    color: var(--color-ink-muted);
    text-align: center;
    line-height: 1.5;
  }

  .report-content :global(em) {
    font-weight: 400;
    color: var(--color-ink-muted);
    font-style: italic;
  }

  .report-content :global(strong) {
    font-weight: 700;
    color: var(--color-ink);
  }

  .report-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-surface-3);
    margin: var(--space-3xl) 0;
  }

  /* ─── More from SEF — text-over-image related-post gallery ─── */
  .more-posts {
    max-width: 1120px;
    margin-inline: auto;
    padding: 0 var(--space-xl) var(--space-5xl);
  }
  .more-posts__head {
    margin-bottom: var(--space-xl);
  }
  .more-posts__eyebrow {
    font-family: var(--font-body);
    font-size: var(--text-label);
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin: 0;
  }
  .more-posts__heading {
    font-family: var(--font-display);
    font-size: var(--text-heading);
    font-weight: 400;
    color: var(--color-ink);
    margin: var(--space-xs) 0 0;
  }
  .more-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }
  .more-card {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    aspect-ratio: 4 / 3;
    border-radius: 8px;
    overflow: hidden;
    isolation: isolate;
    text-decoration: none;
  }
  .more-card__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: -2;
    transition: transform var(--duration-slow) var(--ease-standard);
  }
  .more-card__scrim {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(180deg, rgba(8, 38, 31, 0) 28%, rgba(8, 38, 31, 0.5) 62%, rgba(8, 38, 31, 0.9) 100%);
  }
  .more-card__meta {
    font-family: var(--font-body);
    font-size: var(--text-label);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(244, 238, 229, 0.82);
    padding: 0 var(--space-lg);
  }
  .more-card__title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 400;
    line-height: 1.25;
    color: var(--color-surface);
    margin: var(--space-xs) 0 0;
    padding: 0 var(--space-lg) var(--space-lg);
  }
  @media (hover: hover) and (pointer: fine) {
    .more-card:hover .more-card__img { transform: scale(1.05); }
  }

  /* Responsive */
  @media (max-width: 767px) {
    .more-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .report-back {
      padding: var(--space-3xl) var(--space-md) 0;
    }

    .report-page {
      padding: var(--space-md) var(--space-md) var(--space-4xl);
    }
    .more-posts { padding: 0 var(--space-md) var(--space-4xl); }
  }
</style>
