---
// src/pages/publications/index.astro
// Publications library index — browsable card grid with client-side filter island.
//
// MOD-02: data access ONLY via ../../lib/content adapter — no direct collection queries.
// Progressive enhancement: all cards render without JS; filter island is additive.

import BaseLayout from '../../layouts/BaseLayout.astro';
import { getReports } from '../../lib/content';
import { slugify } from '../../lib/slugify';

const reports = await getReports();

// Derive filter options from the live library so no dropdown ever offers a value
// that matches zero publications (e.g. a "Snapshot" type nobody has published yet).
const allDivisions = [...new Set(reports.map(r => r.data.division))].sort();
const allTypes = [...new Set(reports.map(r => r.data.type))].sort();
const allSectors = [...new Set(reports.flatMap(r => r.data.sector))].sort();

// Friendlier labels for the Type dropdown (values stay the schema enum).
const TYPE_LABELS = {
  Report: 'Research Report',
  Note: 'Market Note',
  Snapshot: 'Snapshot',
  Insight: 'Insight',
};
---

<BaseLayout
  title="Publications | Saigon Equities Forum"
  description="Research and analysis by SEF analysts across Vietnam's markets."
>
  <!-- ─── Library Masthead ─────────────────────────────────────────────── -->
  <section class="pub-masthead">
    <div class="pub-masthead__inner">
      <p class="pub-masthead__eyebrow">SAIGON EQUITIES FORUM</p>
      <h1 class="pub-masthead__headline">Publications</h1>
      <p class="pub-masthead__subhead">Research and analysis by SEF analysts across Vietnam's markets.</p>
      <hr class="pub-masthead__rule" aria-hidden="true" />
    </div>
  </section>

  <!-- ─── Filter Bar ───────────────────────────────────────────────────── -->
  <div class="filter-bar" role="search" aria-label="Filter publications">
    <div class="filter-bar__inner">
      <div class="filter-group">
        <label for="division-select" class="filter-group__label">Division</label>
        <select id="division-select" class="filter-select" data-dim="division">
          <option value="">All divisions</option>
          {allDivisions.map(val => (
            <option value={val}>{val}</option>
          ))}
        </select>
      </div>
      <div class="filter-group">
        <label for="type-select" class="filter-group__label">Format</label>
        <select id="type-select" class="filter-select" data-dim="type">
          <option value="">All formats</option>
          {allTypes.map(val => (
            <option value={val}>{TYPE_LABELS[val] ?? val}</option>
          ))}
        </select>
      </div>
      {allSectors.length > 0 && (
        <div class="filter-group">
          <label for="sector-select" class="filter-group__label">Sector</label>
          <select id="sector-select" class="filter-select" data-dim="sector">
            <option value="">All sectors</option>
            {allSectors.map(val => (
              <option value={val}>{val}</option>
            ))}
          </select>
        </div>
      )}
      <div class="filter-bar__meta">
        <span id="pub-count" class="filter-count" aria-live="polite">
          {reports.length === 1 ? '1 publication' : `${reports.length} publications`}
        </span>
        <button id="filter-reset" class="filter-reset" style="display:none">Clear filters</button>
      </div>
    </div>
  </div>

  <!-- ─── Publication List ───────────────────────────────────────────────── -->
  <div class="pub-list">
    {reports.map((report, index) => (
      <article
        class="pub-row"
        data-division={report.data.division}
        data-type={report.data.type}
        data-sector={report.data.sector.join('|')}
      >
        <div class="pub-row__image">
          {/* Local, schema-typed cover (no external CDN). When final covers are
              delivered, replace the PNG in _assets/ — frontmatter `cover:` already
              points to it, so no code change is needed here. */}
          <img
            src={report.data.cover.src}
            alt={report.data.title}
            width={report.data.cover.width}
            height={report.data.cover.height}
            loading={index < 3 ? "eager" : "lazy"}
          />
        </div>
        <div class="pub-row__content">
          <div class="pub-row__meta">
            <span class="pub-row__division">{report.data.division}</span>
            <span class="pub-row__type">{report.data.type}</span>
            {report.data.sector.map((s) => (
              <span class="pub-row__sector">{s}</span>
            ))}
          </div>
          <h2 class="pub-row__title">
            <a href={`/publications/${report.id}`}>{report.data.title}</a>
          </h2>
          <p class="pub-row__desc">{report.data.description}</p>
          <div class="pub-row__byline">
            <span class="pub-row__analysts">
              {report.data.analysts.map((name, i) => (
                <>
                  {i > 0 && <span>, </span>}
                  <a href={`/team/${slugify(name)}`}>{name}</a>
                </>
              ))}
            </span>
            <span class="pub-row__date">
              {new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' }).format(report.data.publishedAt)}
            </span>
          </div>
          <a href={`/publications/${report.id}`} class="pub-row__cta">Read report →</a>
        </div>
      </article>
    ))}
  </div>

  <!-- ─── Empty State ──────────────────────────────────────────────────── -->
  <div id="pub-empty" class="pub-empty" style="display:none">
    <p class="pub-empty__heading">No publications match these filters yet.</p>
    <p class="pub-empty__body">Try removing a filter, or check back as the library grows.</p>
    <a href="/publications" class="pub-empty__reset">Clear all filters</a>
  </div>

  <!-- ─── Filter Island (is:inline — DOMContentLoaded required) ───────── -->
  <script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    var active = { division: null, type: null, sector: null };
    var cards = document.querySelectorAll('.pub-row');
    var selects = document.querySelectorAll('.filter-select');
    var countEl = document.getElementById('pub-count');
    var emptyEl = document.getElementById('pub-empty');
    var resetEl = document.getElementById('filter-reset');

    function applyFilters() {
      var count = 0;
      cards.forEach(function (card) {
        var match = Object.entries(active).every(function (entry) {
          var dim = entry[0], val = entry[1];
          if (!val) return true;
          if (dim === 'sector') return card.dataset.sector.split('|').includes(val);
          return card.dataset[dim] === val;
        });
        card.style.display = match ? '' : 'none';
        if (match) count++;
      });
      var hasActive = Object.values(active).some(Boolean);
      if (countEl) countEl.textContent = count === 1 ? '1 publication' : count + ' publications';
      if (emptyEl) emptyEl.style.display = count === 0 ? '' : 'none';
      if (resetEl) resetEl.style.display = hasActive ? '' : 'none';
    }

    selects.forEach(function (select) {
      select.addEventListener('change', function () {
        var dim = select.dataset.dim;
        var val = select.value;
        active[dim] = val || null;
        applyFilters();
      });
    });

    resetEl.addEventListener('click', function (e) {
      e.preventDefault();
      selects.forEach(function (select) {
        select.value = '';
      });
      active = { division: null, type: null, sector: null };
      applyFilters();
    });
  });
  </script>
</BaseLayout>

<style>
  /* ── Masthead ────────────────────────────────────────────────────────── */
  .pub-masthead {
    background: var(--color-surface);
    background-image: radial-gradient(ellipse 80% 120% at 60% 50%, rgba(0, 132, 93, 0.06) 0%, transparent 70%);
    height: clamp(180px, 25vw, 280px);
    display: flex;
    align-items: center;
  }

  .pub-masthead__inner {
    max-width: 1280px;
    width: 100%;
    margin-inline: auto;
    padding-inline: var(--space-xl);
    padding-top: var(--space-4xl);
  }

  .pub-masthead__eyebrow {
    font-family: var(--font-body);
    font-size: var(--text-label);
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    margin: 0 0 var(--space-sm) 0;
  }

  .pub-masthead__headline {
    font-family: var(--font-display);
    font-size: var(--text-display);
    font-weight: 400;
    color: var(--color-ink);
    line-height: 1.1;
    margin: 0 0 var(--space-sm) 0;
  }

  .pub-masthead__subhead {
    font-family: var(--font-body);
    font-size: var(--text-body);
    font-weight: 400;
    color: var(--color-ink-muted);
    line-height: 1.65;
    margin: 0;
  }

  .pub-masthead__rule {
    border: none;
    border-top: 1px solid var(--color-gold);
    opacity: 0.4;
    margin: var(--space-lg) 0 0 0;
    width: 60px;
  }

  /* ── Filter Bar ──────────────────────────────────────────────────────── */
  .filter-bar {
    position: sticky;
    top: 64px;
    z-index: 10;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-surface-3);
    padding: var(--space-md) 0;
  }

  .filter-bar__inner {
    max-width: 1280px;
    margin-inline: auto;
    padding-inline: var(--space-xl);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-lg);
  }

  .filter-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .filter-group__label {
    font-family: var(--font-body);
    font-size: var(--text-label);
    font-weight: 400;
    color: var(--color-ink-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .filter-select {
    font-family: var(--font-body);
    font-size: var(--text-body);
    font-weight: 400;
    color: var(--color-ink);
    background: var(--color-surface);
    border: 1px solid var(--color-surface-3);
    border-radius: 4px;
    padding: var(--space-sm) var(--space-md);
    min-width: 180px;
    cursor: pointer;
    transition: border-color var(--duration-fast) var(--ease-standard),
                box-shadow var(--duration-fast) var(--ease-standard);
  }

  .filter-select:hover {
    border-color: var(--color-accent);
  }

  .filter-select:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(0, 132, 93, 0.1);
  }

  .filter-bar__meta {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .filter-count {
    font-family: var(--font-body);
    font-size: var(--text-label);
    font-weight: 400;
    color: var(--color-ink-muted);
    white-space: nowrap;
  }

  .filter-reset {
    font-family: var(--font-body);
    font-size: var(--text-label);
    font-weight: 400;
    color: var(--color-accent);
    background: transparent;
    border: 1px solid var(--color-accent);
    border-radius: 4px;
    padding: var(--space-sm) var(--space-md);
    cursor: pointer;
    transition: background var(--duration-fast) var(--ease-standard),
                color var(--duration-fast) var(--ease-standard);
  }

  .filter-reset:hover {
    background: var(--color-accent);
    color: var(--color-surface);
  }

  @media (max-width: 767px) {
    /* Don't pin the filters on mobile — three stacked dropdowns are tall enough
       to swallow the viewport, and a sticky block would follow you down the page
       and bury the publications. Let them scroll away instead. */
    .filter-bar {
      position: static;
      top: auto;
      padding: var(--space-sm) 0 var(--space-md);
    }

    .filter-bar__inner {
      flex-direction: row;
      flex-wrap: wrap;
      align-items: end;
      gap: var(--space-sm);
      padding-inline: var(--space-md);
    }

    /* Two compact filters per row instead of one full-width per line */
    .filter-group {
      flex: 1 1 calc(50% - var(--space-sm));
      min-width: 0;
      gap: 2px;
    }

    .filter-select {
      width: 100%;
      min-width: 0;
      padding: var(--space-xs) var(--space-sm);
    }

    .filter-bar__meta {
      flex-basis: 100%;
      margin-left: 0;
      margin-top: var(--space-xs);
      justify-content: space-between;
    }
  }

  /* ── Publication List — editorial horizontal rows ─────────────────────── */
  /* Each publication owns a full-width band: cover on the left, content on the
     right, separated from its neighbours by a single hairline rule. No cards,
     no columns — reads like the contents page of a research journal. */
  .pub-list {
    max-width: 1120px;
    margin-inline: auto;
    padding: var(--space-2xl) var(--space-xl) var(--space-4xl);
  }

  .pub-row {
    display: grid;
    grid-template-columns: minmax(0, 4fr) minmax(0, 6fr);
    gap: clamp(var(--space-lg), 4vw, var(--space-3xl));
    align-items: center;
    padding: var(--space-2xl) 0;
    border-top: 1px solid var(--color-surface-3);
  }

  .pub-row:first-child {
    border-top: none;
    padding-top: var(--space-md);
  }

  /* Cover */
  .pub-row__image {
    overflow: hidden;
    border-radius: 4px;
    background: var(--color-surface-2);
    aspect-ratio: 16 / 10;
  }

  .pub-row__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--duration-slow, 0.5s) var(--ease-standard);
  }

  .pub-row:hover .pub-row__image img {
    transform: scale(1.03);
  }

  /* Content column */
  .pub-row__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .pub-row__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
    font-family: var(--font-body);
    font-size: var(--text-label);
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .pub-row__division {
    color: var(--color-accent);
  }

  .pub-row__type,
  .pub-row__sector {
    color: var(--color-ink-muted);
  }

  /* Hairline dot separators between meta items */
  .pub-row__meta > * + *::before {
    content: '·';
    margin-right: var(--space-sm);
    color: var(--color-surface-3);
  }

  .pub-row__title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.4vw, 2rem);
    font-weight: 400;
    line-height: 1.2;
    margin: 0 0 var(--space-md) 0;
  }

  .pub-row__title a {
    color: var(--color-ink);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-standard);
  }

  .pub-row:hover .pub-row__title a,
  .pub-row__title a:hover {
    color: var(--color-accent);
  }

  .pub-row__desc {
    font-family: var(--font-body);
    font-size: var(--text-body);
    font-weight: 400;
    color: var(--color-ink-muted);
    line-height: 1.65;
    margin: 0 0 var(--space-lg) 0;
    max-width: 56ch;
  }

  .pub-row__byline {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-body);
    font-size: var(--text-label);
    font-weight: 400;
    color: var(--color-ink-muted);
    margin-bottom: var(--space-lg);
  }

  .pub-row__analysts a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .pub-row__analysts a:hover {
    text-decoration: underline;
  }

  .pub-row__date::before {
    content: '·';
    margin-right: var(--space-sm);
    color: var(--color-surface-3);
  }

  .pub-row__cta {
    font-family: var(--font-body);
    font-size: var(--text-label);
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-accent);
    text-decoration: none;
    margin-top: auto;
    transition: gap var(--duration-fast) var(--ease-standard);
  }

  .pub-row__cta:hover {
    color: var(--color-ink);
  }

  /* Stack to a single column on tablet/mobile */
  @media (max-width: 767px) {
    .pub-row {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
      padding: var(--space-xl) 0;
    }

    .pub-row__image {
      aspect-ratio: 16 / 9;
    }
  }

  /* ── Empty State ─────────────────────────────────────────────────────── */
  .pub-empty {
    max-width: 1280px;
    margin-inline: auto;
    padding: var(--space-4xl) var(--space-xl);
    text-align: center;
  }

  .pub-empty__heading {
    font-family: var(--font-display);
    font-size: var(--text-heading);
    font-weight: 400;
    color: var(--color-ink);
    margin: 0 0 var(--space-md) 0;
    max-width: none;
  }

  .pub-empty__body {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-ink-muted);
    max-width: 40ch;
    margin: 0 auto var(--space-xl);
  }

  .pub-empty__reset {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-accent);
  }

  .pub-empty__reset:hover {
    text-decoration: underline;
  }
</style>
