  .reveal.is-visible .step:nth-child(3) { transition-delay: 160ms; }
  .reveal.is-visible .step:nth-child(4) { transition-delay: 240ms; }

  /* Stat underline wipes in from center after the count-up begins. */
  .js .reveal .stat__num::after {
