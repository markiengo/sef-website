     ───────────────────────────────────────────────────────────────────────── */
  /* Slim connective proof-strip: sits close under the hero (logos read as the
     hero's proof), with a single clean gap into the network band below. */
  .marquee-section {
    padding-block: var(--space-3xl) var(--space-2xl);
  }
  .marquee-section__lead {
    text-align: center;
    font-family: var(--font-body);
    font-size: var(--text-body);
    font-weight: 400;
    color: var(--color-ink-muted);
    margin: 0 0 var(--space-lg);
  }
  /* The overflow mask — the page itself never gets a horizontal scrollbar. */
  .marquee {
    overflow: hidden;
    background: var(--color-surface-2);
    padding-block: var(--space-lg);
    /* Own stacking context so the logos' multiply blend only mixes with this
       band, not whatever sits behind it. */
    isolation: isolate;
  }
  .marquee__track {
    display: flex;
    align-items: center;
    width: max-content;
  }
  /* Each logo carries its own trailing margin so a "copy" is self-contained →
     translateX(-50%) loops with no half-gap seam.
     The source files ship on mixed backgrounds (some white boxes, some
     transparent, some colour discs). mix-blend-mode: multiply drops the white
     into the band so only the mark shows; grayscale unifies them into one
     monochrome family. Hover restores colour. */
  .marquee__logo {
    flex: none;
    height: 50px;        /* +40% (was 36px) — fewer schools, so each reads larger */
    max-height: 50px;
    width: auto;
    object-fit: contain;
    margin-inline-end: clamp(var(--space-xl), 5vw, var(--space-4xl));
    mix-blend-mode: multiply;
    filter: grayscale(1);
    opacity: 0.72;
    transition:
      filter var(--duration-standard) var(--ease-standard),
      opacity var(--duration-standard) var(--ease-standard);
  }
  /* Constant motion = linear easing; only translate animates (GPU). Gated so
     reduced-motion users get no drift. */
  @media (prefers-reduced-motion: no-preference) {
    .marquee__track {
      animation: marquee-scroll 36s linear infinite; /* +10% speed (was 40s) */
    }
    @keyframes marquee-scroll {
      to { transform: translateX(-50%); }
    }
  }
  @media (hover: hover) and (pointer: fine) {
    .marquee:hover .marquee__track {
      animation-play-state: paused;
    }
    .marquee__logo:hover {
      filter: grayscale(0);
      opacity: 1;
    }
  }
  /* Reduced motion: stop the loop, hide the duplicate, wrap to a static centered
     row — all 8 logos still visible, no clipping. */
  @media (prefers-reduced-motion: reduce) {
    .marquee__track {
      flex-wrap: wrap;
      justify-content: center;
      width: auto;
    }
    .marquee__logo {
      margin: var(--space-md) var(--space-lg);
    }
    .marquee__logo[aria-hidden="true"] {
      display: none;
    }
  }

