  .closing::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: radial-gradient(
      440px circle at var(--mx, 50%) var(--my, 50%),
      rgba(200, 157, 41, 0.22) 0%,
      rgba(0, 132, 93, 0.20) 38%,
