  }

  /* ─────────────────────────────────────────────────────────────────────────
     SCROLL-REVEAL — hidden state gated behind `.js` so non-JS users see all.
     ───────────────────────────────────────────────────────────────────────── */
  .js .reveal {
    opacity: 0;
    transform: translateY(16px);
    transition:
